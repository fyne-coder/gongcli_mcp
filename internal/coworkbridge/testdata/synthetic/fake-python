#!/usr/bin/env bash
# Synthetic interpreter for gongcowork tests. Records argv and simulates
# fixed gong_quarterly_review module outputs. Makes zero Gong network calls.
set -euo pipefail

# Installed as <project>/.venv-host/bin/python in synthetic fixtures.
ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
LOG="${ROOT}/argv.log"
mkdir -p "$(dirname "$LOG")"
{
  printf 'ARGS\t%s' "$0"
  for arg in "$@"; do
    printf '\t%s' "$arg"
  done
  printf '\n'
} >>"$LOG"

if [[ "${1:-}" != "-m" ]]; then
  echo "expected -m <module>" >&2
  exit 2
fi
MODULE="${2:-}"
shift 2 || true

extract_item_id() {
  # Prefer staged-*.ok markers / known synthetic JSON shape without host python3.
  local input="$1"
  local line
  line="$(tr '\n' ' ' <"$input")"
  if [[ "$line" =~ \"item_id\"[[:space:]]*:[[:space:]]*\"([^\"]+)\" ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi
  echo "unable to extract item_id from $input" >&2
  return 1
}

pending_item_ids_json() {
  local pending=()
  local item
  for item in item-1 item-2; do
    if [[ ! -f "${ROOT}/staged-${item}.ok" ]]; then
      pending+=("$item")
    fi
  done
  if [[ ${#pending[@]} -eq 0 ]]; then
    printf '[]'
    return
  fi
  printf '['
  local i
  for i in "${!pending[@]}"; do
    if [[ $i -gt 0 ]]; then
      printf ','
    fi
    printf '"%s"' "${pending[$i]}"
  done
  printf ']'
}

case "$MODULE" in
	 gong_quarterly_review.segment_pipeline)
		if [[ "${1:-}" != "check-freshness" ]]; then
			echo "segment_pipeline only supports check-freshness in synthetic companion" >&2
			exit 2
		fi
		if [[ -f "${ROOT}/freshness-not-ok" ]]; then
			echo '{"ok":false,"reason":"synthetic stale gate"}'
			exit 1
		fi
		echo '{"ok":true,"freshness":{"synthetic":true},"age_seconds":1}'
		exit 0
		;;
  gong_quarterly_review.local_bridge_readiness)
    if [[ -f "${ROOT}/readiness-not-ok" ]]; then
      echo '{"ok":false,"stage":"synthetic-refused","checks":{"approved_root":{"ok":false}}}'
      exit 0
    fi
    echo '{"ok":true,"synthetic":true,"module":"local_bridge_readiness"}'
    exit 0
    ;;
  gong_quarterly_review.preflight_gate_cli)
    QUARTER_ROOT=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --quarter-root) QUARTER_ROOT="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    if [[ -f "${ROOT}/fail-gate" ]]; then
      echo '{"ok":false,"stage":"synthetic-gate-refused"}'
      exit 0
    fi
    if [[ -z "$QUARTER_ROOT" ]]; then
      echo "gate requires --quarter-root" >&2
      exit 2
    fi
    mkdir -p "$QUARTER_ROOT"
    printf '{"ok":true,"synthetic":true}\n' >"${QUARTER_ROOT}/pre-drilldown-gate.json"
    echo '{"ok":true,"gate":{"synthetic":true}}'
    exit 0
    ;;
  gong_quarterly_review.response_receipt)
    ITEM=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --item-id) ITEM="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    if [[ -f "${ROOT}/fail-receipt" ]]; then
      echo "synthetic receipt failure" >&2
      exit 1
    fi
    echo "{\"ok\":true,\"item_id\":\"${ITEM}\",\"module\":\"response_receipt\"}"
    exit 0
    ;;
  gong_quarterly_review.response_adapter)
    ITEM=""
    OUTPUT=""
    RAW=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --item-id) ITEM="$2"; shift 2 ;;
        --output) OUTPUT="$2"; shift 2 ;;
        --raw-response) RAW="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    if [[ -f "${ROOT}/fail-adapter" ]]; then
      echo "synthetic adapter failure" >&2
      exit 1
    fi
    mkdir -p "$(dirname "$OUTPUT")"
    printf '{"item_id":"%s","status":"ok","body_text":"synthetic","source":"%s"}\n' "$ITEM" "$RAW" >"$OUTPUT"
    echo "{\"ok\":true,\"item_id\":\"${ITEM}\",\"module\":\"response_adapter\"}"
    exit 0
    ;;
  gong_quarterly_review.stage_rehearsal_capture)
    INPUT=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --input) INPUT="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    if [[ -f "${ROOT}/fail-stage" ]]; then
      echo "synthetic stage failure" >&2
      exit 1
    fi
    ITEM="$(extract_item_id "$INPUT")"
    MARK="${ROOT}/staged-${ITEM}.ok"
    printf 'staged\n' >"$MARK"
    echo "{\"ok\":true,\"item_id\":\"${ITEM}\",\"module\":\"stage_rehearsal_capture\"}"
    exit 0
    ;;
  gong_quarterly_review.candidate_selection_workflow)
    SUBCOMMAND="${1:-}"
    shift || true
    CONFIG=""
    STATE=""
    OUTPUT=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --config) CONFIG="$2"; shift 2 ;;
        --state) STATE="$2"; shift 2 ;;
        --output) OUTPUT="$2"; shift 2 ;;
        --approved-root|--target-dir|--scratch-root|--contract-model-id|--cowork-ui-display-name) shift 2 ;;
        *) shift ;;
      esac
    done
    if [[ -z "$CONFIG" || -z "$STATE" || -z "$OUTPUT" ]]; then
      echo "selection workflow requires --config --state --output" >&2
      exit 2
    fi
    # Record whether stdin was supplied without writing a temp body file.
    if [[ -f "${ROOT}/fail-selection" ]]; then
      echo "synthetic selection failure" >&2
      exit 1
    fi
    case "$SUBCOMMAND" in
      preflight)
        if [[ -f "${ROOT}/selection-not-ok" ]]; then
          echo '{"ok":false,"stage":"synthetic-selection-refused"}'
          exit 0
        fi
        mkdir -p "$(dirname "$STATE")" "$(dirname "$OUTPUT")"
        printf '{"ok":true,"stage":"preflight"}\n' >"$STATE"
        echo '{"ok":true,"stage":"preflight","synthetic":true}'
        exit 0
        ;;
      persist_discovery_response)
        if [[ -t 0 ]]; then
          echo "discovery response requires stdin JSON" >&2
          exit 2
        fi
        BODY="$(cat)"
        if [[ -z "$BODY" ]]; then
          echo "empty discovery stdin" >&2
          exit 2
        fi
        # Refuse argv-shaped leakage of body fields.
        printf 'STDIN\tpersist_discovery_response\t%d\n' "${#BODY}" >>"$LOG"
        mkdir -p "$(dirname "$STATE")"
        printf '%s\n' "$BODY" >"${STATE}.discovery.json"
        echo '{"ok":true,"stage":"discovery-persisted","synthetic":true}'
        exit 0
        ;;
      get_next_query)
        echo '{"ok":true,"stage":"next-query","query_id":"q-1","synthetic":true}'
        exit 0
        ;;
      persist_query_response)
        if [[ -t 0 ]]; then
          echo "query response requires stdin JSON envelope" >&2
          exit 2
        fi
        BODY="$(cat)"
        if [[ -z "$BODY" ]]; then
          echo "empty query stdin" >&2
          exit 2
        fi
        printf 'STDIN\tpersist_query_response\t%d\n' "${#BODY}" >>"$LOG"
        if [[ "$BODY" != *'"query_id"'* || "$BODY" != *'"response"'* ]]; then
          echo "query envelope missing query_id/response" >&2
          exit 2
        fi
        mkdir -p "$(dirname "$STATE")"
        printf '%s\n' "$BODY" >"${STATE}.query.json"
        echo '{"ok":true,"stage":"query-persisted","synthetic":true}'
        exit 0
        ;;
      finalize_selection)
        if [[ -f "${ROOT}/selection-finalize-not-ok" ]]; then
          echo '{"ok":false,"stage":"finalize-refused"}'
          exit 0
        fi
        mkdir -p "$(dirname "$OUTPUT")"
        printf '{"ok":true,"stage":"finalized","synthetic":true}\n' >"$OUTPUT"
        echo '{"ok":true,"stage":"finalized","synthetic":true}'
        exit 0
        ;;
      get_selection_status)
        if [[ -f "${ROOT}/selection-status-not-ok" ]]; then
          echo '{"ok":false,"stage":"status-refused","synthetic":true}'
          exit 0
        fi
        echo '{"ok":true,"stage":"status","synthetic":true}'
        exit 0
        ;;
      *)
        echo "unknown selection subcommand: $SUBCOMMAND" >&2
        exit 2
        ;;
    esac
    ;;
  gong_quarterly_review.verify_ordering_rehearsal)
    FINALIZE=0
    OUTPUT=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --finalize) FINALIZE=1; shift ;;
        --recover-pin)
          echo "recover-pin is forbidden in synthetic companion" >&2
          exit 2
          ;;
        --output) OUTPUT="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    if [[ -f "${ROOT}/verifier-refuse" ]]; then
      echo '{"ok":false,"stage":"refused","pending_item_ids":["item-1"],"ordering_journal":{"ok":true},"synthetic":true}'
      exit 1
    fi
    if [[ -f "${ROOT}/verifier-not-accepted" ]]; then
      echo '{"ok":true,"stage":"pending-items","pending_item_ids":["item-1"],"ordering_journal":{"ok":true},"synthetic":true}'
      exit 0
    fi
    if [[ "$FINALIZE" -eq 1 ]]; then
      if [[ -z "$OUTPUT" ]]; then
        echo "finalize requires --output" >&2
        exit 2
      fi
      mkdir -p "$(dirname "$OUTPUT")"
      if [[ -f "${ROOT}/verifier-wrong-final-stage" ]]; then
        echo '{"ok":true,"stage":"captured-pending-finalize","ordering_journal":{"ok":true},"synthetic":true}'
        exit 0
      fi
      mkdir -p "${ROOT}/runs/demo/markers" "${ROOT}/runs/demo"
      printf '{"complete":true}\n' >"${ROOT}/runs/demo/markers/capture-complete.marker.json"
      printf '{"complete":true}\n' >"${ROOT}/runs/demo/completion.pin.json"
      printf '{"ok":true,"stage":"finalized","ordering_journal":{"ok":true},"synthetic":true}\n' >"$OUTPUT"
      echo '{"ok":true,"stage":"finalized","ordering_journal":{"ok":true},"synthetic":true}'
      exit 0
    fi
    if [[ -f "${ROOT}/verifier-missing-pending" ]]; then
      echo '{"ok":true,"stage":"pending-items","ordering_journal":{"ok":true},"synthetic":true}'
      exit 0
    fi
    PENDING="$(pending_item_ids_json)"
    if [[ "$PENDING" == "[]" ]]; then
      echo '{"ok":true,"stage":"captured-pending-finalize","pending_item_ids":[],"ordering_journal":{"ok":true},"synthetic":true,"finalize":false}'
    else
      echo "{\"ok\":true,\"stage\":\"pending-items\",\"pending_item_ids\":${PENDING},\"ordering_journal\":{\"ok\":true},\"synthetic\":true,\"finalize\":false}"
    fi
    exit 0
    ;;
  *)
    echo "unknown synthetic module: $MODULE" >&2
    exit 2
    ;;
esac
