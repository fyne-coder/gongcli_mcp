# Public Claude-facing gateway base URL. Must be HTTPS in production.
PUBLIC_BASE_URL=https://mcp.customer.example.com

# Private upstream gongmcp HTTP URL. This should be reachable only from the
# gateway service.
GATEWAY_UPSTREAM_URL=http://gongmcp:8080
GATEWAY_ADDR=:8090

# Cognito issuer, not the Cognito hosted UI domain.
COGNITO_ISSUER_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=replace-with-dedicated-claude-app-client-id
COGNITO_REQUIRED_SCOPE=gongmcp/read
COGNITO_SCOPES_SUPPORTED=gongmcp/read

# Access policy. At least one group, subject, or email gate is required. Prefer
# group or subject enforcement. Email is available only if Cognito includes it
# in the access token.
COGNITO_REQUIRED_GROUP=gongmcp-users
COGNITO_GROUP_CLAIM=cognito:groups
COGNITO_ALLOWED_SUBJECTS=
COGNITO_ALLOWED_EMAILS=

# Optional Dynamic Client Registration fallback. Leave disabled unless Claude
# cannot use the pre-registered app client through Advanced settings.
GATEWAY_DCR_ENABLED=0
# Required only when GATEWAY_DCR_ENABLED=1. This is the Cognito hosted UI
# domain, not the issuer URL above.
COGNITO_DOMAIN_URL=https://your-domain.auth.us-east-1.amazoncognito.com
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_DCR_ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback
COGNITO_DCR_ALLOWED_SCOPES=openid,email,gongmcp/read
COGNITO_DCR_IDENTITY_PROVIDERS=JumpCloud
COGNITO_DCR_CLIENT_NAME_PREFIX=gongmcp-dcr
COGNITO_DCR_ACCESS_TOKEN_MINUTES=60

# Optional browser CORS allowlist for preflight-capable MCP clients. Claude.ai
# hosted connector calls are server-side, but keep this explicit if browser
# clients are introduced.
GATEWAY_ALLOWED_ORIGINS=https://claude.ai

# Mount this file as a secret. Do not put the actual token in this env file.
GATEWAY_INTERNAL_BEARER_TOKEN_FILE=/run/secrets/gongmcp_token
