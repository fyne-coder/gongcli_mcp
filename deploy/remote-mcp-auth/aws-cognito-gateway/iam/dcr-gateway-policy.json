{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CognitoDCRGatewayRuntime",
      "Effect": "Allow",
      "Action": [
        "cognito-idp:CreateUserPoolClient",
        "cognito-idp:DescribeUserPoolClient"
      ],
      "Resource": "arn:aws:cognito-idp:<AWS_REGION>:<AWS_ACCOUNT_ID>:userpool/<USER_POOL_ID>"
    }
  ]
}
