# TradeCentric/company direct OIDC remote MCP gateway example.
# Do not commit real values.

PUBLIC_BASE_URL=https://mcp.company.example.com
GATEWAY_UPSTREAM_URL=http://gongmcp:8080
GATEWAY_ADDR=:8090

# Direct OIDC first. These aliases avoid making Cognito the default path.
OIDC_AUTH_PROFILE=direct-oidc
OIDC_ISSUER_URL=https://issuer.company.example.com
# Set this from the provider's OIDC discovery jwks_uri. Do not assume every
# provider uses the Cognito-style issuer/.well-known/jwks.json path. Leave
# blank to use issuer + "/.well-known/jwks.json"; override when discovery's
# jwks_uri differs.
OIDC_JWKS_URL=
OIDC_CLIENT_ID=replace-with-dedicated-claude-app-client-id

# Provider-neutral direct-OIDC scope and user policy.
OIDC_REQUIRED_SCOPE=gongmcp/read
OIDC_SCOPES_SUPPORTED=gongmcp/read

# Preferred production gate. Use one or more dedicated JumpCloud/company groups
# for the MCP connector. Do not use broad admin groups or email allowlists as
# the final production policy. For first non-prod smoke, subject allowlist is a
# reasonable temporary fallback while IdP group mapping is being finished.
OIDC_REQUIRED_GROUP=GongMCP-Users
# For rollout windows or renamed directory groups, prefer this plural form.
# The gateway authorizes users who have any one configured group.
# OIDC_REQUIRED_GROUPS=GongMCP-Users,AI-Data-Readers
# OIDC_ALLOWED_GROUPS is a readability alias for OIDC_REQUIRED_GROUPS.
# Set this to the access-token group claim emitted by the IdP. JumpCloud/Ory
# tokens may use groups, memberOf, or nested ext.memberOf.
OIDC_GROUP_CLAIM=groups
OIDC_ALLOWED_SUBJECTS=
OIDC_ALLOWED_EMAILS=

# Legacy COGNITO_* names remain backward-compatible aliases in the gateway.
# Use them only for existing deployments or Cognito-specific fallback docs.

# Leave disabled for direct OIDC. Uncomment and fill these only if the company
# explicitly chooses Cognito or needs Cognito-backed DCR fallback.
GATEWAY_DCR_ENABLED=0
# COGNITO_DOMAIN_URL=https://your-domain.auth.us-east-1.amazoncognito.com
# COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# COGNITO_DCR_ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback
# COGNITO_DCR_ALLOWED_SCOPES=openid,email,gongmcp/read
# COGNITO_DCR_IDENTITY_PROVIDERS=
# COGNITO_DCR_CLIENT_NAME_PREFIX=gongmcp-dcr
# COGNITO_DCR_ACCESS_TOKEN_MINUTES=60

GATEWAY_ALLOWED_ORIGINS=https://claude.ai

# Mount this as a secret in production. Do not put the actual token here.
GATEWAY_INTERNAL_BEARER_TOKEN_FILE=/run/secrets/gongmcp_token
