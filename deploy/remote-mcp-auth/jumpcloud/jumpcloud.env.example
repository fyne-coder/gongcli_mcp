PUBLIC_BASE_URL=https://gong-mcp.example.com
HTTP_BIND=127.0.0.1:8080

# JumpCloud OIDC app settings. Use the issuer for the customer's JumpCloud
# region, for example https://oauth.id.jumpcloud.com/ or
# https://oauth.id.eu.jumpcloud.com/.
JUMPCLOUD_OIDC_ISSUER_URL=https://oauth.id.jumpcloud.com
JUMPCLOUD_OIDC_CLIENT_ID=replace-with-jumpcloud-client-id
JUMPCLOUD_OIDC_CLIENT_SECRET=replace-with-jumpcloud-client-secret
JUMPCLOUD_REQUIRED_GROUP=

# Pilot authorization policy.
PILOT_ALLOWED_EMAILS=approved-user@example.com
# Trusted proxy identity headers are disabled by default. Enable only behind a
# reviewed gateway that overwrites identity headers, and use the exact gateway
# source CIDR rather than a broad Docker private range.
TRUST_PROXY_HEADERS=0
TRUST_PROXY_CIDRS=

# oauth2-proxy requires a 32-byte base64 cookie secret.
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-byte-base64-secret

# Internal gongmcp service.
GONGMCP_IMAGE=ghcr.io/fyne-coder/gongcli_mcp/gongmcp:v0.4.2
GONGMCP_DB=/srv/gongctl/runtime/gong-mcp-governed.db
GONGMCP_BEARER_TOKEN_FILE=/srv/gongctl/secrets/gongmcp_token
GONGMCP_TOOL_PRESET=business-pilot
GONGMCP_ALLOWED_ORIGINS=https://gong-mcp.example.com
