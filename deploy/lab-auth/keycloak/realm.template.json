{
  "realm": "gong-lab",
  "enabled": true,
  "displayName": "gongctl Auth Lab",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "loginWithEmailAllowed": true,
  "groups": [
    {
      "name": "gong-mcp-users"
    }
  ],
  "users": [
    {
      "username": "pilot@example.com",
      "email": "pilot@example.com",
      "firstName": "Pilot",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "groups": [
        "/gong-mcp-users"
      ],
      "realmRoles": [
        "offline_access"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "__PILOT_PASSWORD__",
          "temporary": false
        }
      ]
    },
    {
      "username": "blocked@example.com",
      "email": "blocked@example.com",
      "firstName": "Blocked",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "__BLOCKED_PASSWORD__",
          "temporary": false
        }
      ]
    },
    {
      "username": "test@fyne-llc.com",
      "email": "test@fyne-llc.com",
      "firstName": "Test",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "groups": [
        "/gong-mcp-users"
      ],
      "realmRoles": [
        "offline_access"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "__TEST_PASSWORD__",
          "temporary": false
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "gong-lab-proxy",
      "name": "gongctl lab proxy",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "__OIDC_CLIENT_SECRET__",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "__LAB_PUBLIC_BASE_URL__/oauth2/callback"
      ],
      "webOrigins": [
        "__LAB_PUBLIC_BASE_URL__"
      ],
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "audience-gong-lab-proxy",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "gong-lab-proxy",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ]
}
