LAB_VM=ssh-user@lab-host.example.com
LAB_PUBLIC_BASE_URL=https://lab.example.com
LAB_DB=/path/to/synthetic-gong.db
REMOTE_ROOT=/srv/gongctl
LAB_APPROVED_EMAIL=approved-user@example.test
LAB_SECONDARY_EMAIL=secondary-user@example.test
LAB_BLOCKED_EMAIL=blocked-user@example.test
LAB_ALLOWED_EMAILS=approved-user@example.test,secondary-user@example.test
# Trusted proxy identity headers are disabled by default. Enable only behind a
# reviewed gateway that overwrites identity headers, and use the exact gateway
# source CIDR rather than a broad Docker private range.
TRUST_PROXY_HEADERS=0
TRUST_PROXY_CIDRS=
KEYCLOAK_ADMIN_PASSWORD=change-this-admin-password
OIDC_CLIENT_SECRET=change-this-client-secret
OAUTH2_PROXY_COOKIE_SECRET=base64-32-byte-secret
