# Copy to an ignored file, for example /srv/gongctl/single-vm.env, and replace
# every value before using real customer data.

GONGCTL_IMAGE=ghcr.io/fyne-coder/gongcli_mcp/gongctl:v0.4.4
GONGMCP_IMAGE=ghcr.io/fyne-coder/gongcli_mcp/gongmcp:v0.4.4

POSTGRES_BIND=127.0.0.1:55432
GONGMCP_BIND=127.0.0.1:8080

GONGCTL_SOURCE_DB=gongctl_source
GONGCTL_MCP_DB=gongctl_mcp
GONGCTL_POSTGRES_USER=gongctl_operator
GONGCTL_POSTGRES_PASSWORD=replace-with-operator-password
GONGMCP_READER_ROLE=gongmcp_business_reader
GONGMCP_READER_PASSWORD=replace-with-reader-password

GONGMCP_TOOL_PRESET=business-workbench
GONGMCP_ALLOWED_ORIGINS=https://gong-mcp.example.com
GONGMCP_BEARER_TOKEN_FILE=/srv/gongctl/secrets/gongmcp_token

AI_GOVERNANCE_CONFIG=/srv/gongctl/secrets/ai-governance.yaml
GONGCTL_TRANSCRIPT_DIR=/srv/gongctl/transcripts
GONGCTL_CONFIG_DIR=/srv/gongctl/config

GONG_ACCESS_KEY=replace-with-gong-access-key
GONG_ACCESS_KEY_SECRET=<set-gong-secret>
GONG_BASE_URL=
